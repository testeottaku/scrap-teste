const express = require('express');
const axios = require('axios');
const cheerio = require('cheerio');
const cors = require('cors');

const app = express();
app.use(cors());

app.get('/api/anime', async (req, res) => {
    const slug = req.query.url || 'one-piece-todos-os-episodios';
    const targetUrl = `https://animefire.io/animes/${slug}`;

    try {
        const { data } = await axios.get(targetUrl, {
            headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/122.0.0.0 Safari/537.36' }
        });
        const $ = cheerio.load(data);

        const animeData = {
            titulo: $('.div_anime_names h1').text().trim(),
            // Captura o data-src para a imagem não ficar em branco
            capa: $(".sub_animepage_img img").attr("data-src") || $(".sub_animepage_img img").attr("src"),
            // Captura a sinopse exata da sua imagem
            sinopse: $(".divSinopse .spanAnimeInfo").text().trim(),
            generos: [],
            episodios: []
        };

        // Captura gêneros reais e limpa lixo como "Voltar"
        $('.mr-1.spanGenerosLink').each((i, el) => {
            const g = $(el).text().trim();
            if (g && g !== "Voltar") animeData.generos.push(g);
        });

        // Captura a lista de episódios
        $('.video_list_arrow a.Ep').each((i, el) => {
            animeData.episodios.push({
                nome: $(el).text().trim(),
                link: $(el).attr('href')
            });
        });

        res.json(animeData);
    } catch (error) {
        res.status(500).json({ erro: "Erro ao extrair dados" });
    }
});

// O '0.0.0.0' permite que o navegador encontre o servidor mais facilmente
app.listen(3000, '0.0.0.0', () => console.log("Servidor Draksyon rodando na porta 3000"));
